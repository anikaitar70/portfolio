# Server
PORT=4000
NODE_ENV=production

# Comma-separated allowed origins (no trailing slash)
ALLOWED_ORIGINS=https://anikait.page,https://www.anikait.page

# Generate with: npm run hash-password
ADMIN_PASSWORD_HASH=

# Random 64-char hex: openssl rand -hex 32
JWT_SECRET=

# Random 32-char hex for client ingest (also set NEXT_PUBLIC_TELEMETRY_KEY in frontend)
INGEST_KEY=

# Paths (VPS defaults)
WEB_ROOT=/var/www/anikait.page
DATA_DIR=/var/lib/portfolio-api
RESUME_FILENAME=Anikait_Resume.pdf
